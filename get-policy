#!/usr/bin/env python3
"""Read the proxy action log and emit a least-privilege IAM policy JSON.

Usage (inside agent container):
    get-policy                  # print to stdout
    get-policy > policy.json    # save to file
"""
import json
import os
import sys
from pathlib import Path

ACTION_LOG = Path(os.environ.get("ACTION_LOG_PATH", "/run/proxy/actions.log"))

if not ACTION_LOG.exists():
    print(f"No action log found at {ACTION_LOG}. Run some AWS commands first.", file=sys.stderr)
    sys.exit(1)

actions = sorted({line.strip() for line in ACTION_LOG.read_text().splitlines() if line.strip()})

if not actions:
    print("Action log is empty. Run some AWS commands first.", file=sys.stderr)
    sys.exit(1)

policy = {
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ProxyRecordedActions",
            "Effect": "Allow",
            "Action": actions,
            "Resource": "*",
        }
    ],
}

print(json.dumps(policy, indent=2))
