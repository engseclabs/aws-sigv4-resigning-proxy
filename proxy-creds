#!/usr/bin/env python3
"""
credential_process helper: connect to the proxy's creds.sock and print the
credential JSON the AWS SDK expects.

Install to /usr/local/bin/proxy-creds in the agent container and add to
~/.aws/config:

    [profile proxy]
    credential_process = /usr/local/bin/proxy-creds

The SDK calls this when credentials are absent or near expiry, caches the
result until the returned Expiration, then calls again.
"""

import json
import os
import socket
import sys

SOCK_PATH = os.environ.get("PROXY_SOCK_PATH", "/run/proxy/creds.sock")


def main() -> None:
    if not os.path.exists(SOCK_PATH):
        print(
            f"proxy-creds: socket not found at {SOCK_PATH}",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.connect(SOCK_PATH)
            data = b""
            while chunk := s.recv(4096):
                data += chunk
    except OSError as exc:
        print(f"proxy-creds: could not connect to {SOCK_PATH}: {exc}", file=sys.stderr)
        sys.exit(1)

    try:
        creds = json.loads(data)
    except json.JSONDecodeError as exc:
        print(f"proxy-creds: invalid JSON from socket: {exc}", file=sys.stderr)
        sys.exit(1)

    # AWS SDK expects exactly these fields.
    print(json.dumps(creds))


if __name__ == "__main__":
    main()
